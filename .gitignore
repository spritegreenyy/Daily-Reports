# 只纳入 日报/ 和 日报站/，其余全部忽略
/*
!/.gitignore
!/README.md
!/index.html
!/日报/
!/日报站/
!/automation/
/automation/**
!/automation/tide_backtest.py
!/automation/local/
/automation/local/**
!/automation/local/kol_build.py
!/automation/local/kol_pull.py
!/automation/local/kol_indices.py
!/automation/local/kol_emphasis.py
!/automation/local/kol_accounts_merge.py
!/automation/local/kol_soft_accounts.yaml
!/automation/local/test_kol_indices.py
!/automation/local/test_kol_emphasis.py
!/automation/local/run_daily.sh
!/automation/local/tide_report.py
!/kol_digest/
/kol_digest/**
!/kol_digest/scripts/
/kol_digest/scripts/**
!/kol_digest/scripts/build_web.py

# 日报里的打包 zip 和生成产物不进仓库
日报/*.zip
日报站/发送包/
# 交互图表的中间数值文件(HTML已自包含,原始json不入公开仓库)
日报/*/*_data.json

.DS_Store
__pycache__/

# 内部部署文档不进公开仓库(含服务器信息),仅本地留存
日报站/自动化与部署方案.md
